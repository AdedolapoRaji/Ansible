---
- hosts: all
  become: yes
  tasks:
    - name: install java
      yum:
        name: java-1.8.0-openjdk
        state: present

    - name: download and extract tomcat
      unarchive:
        src: "https://archive.apache.org/dist/tomcat/tomcat-9/v9.0.91/bin/apache-tomcat-9.0.91.tar.gz"
        dest: /opt/
        remote_src: yes
        creates: /opt/apache-tomcat-9.0.91

    - name: Create symlink
      file:
        src: /opt/apache-tomcat-9.0.91
        dest: /opt/tomcat
        state: link

    - name: setting the roles in tomcat-user.xml
      template:
        src: tomcat-users.xml  # Looks for this file in your current folder
        dest: /opt/tomcat/conf/tomcat-users.xml

    - name: configure manager access in context.xml
      template:
        src: context.xml      # Ensure this file exists next to your playbook
        dest: /opt/tomcat/webapps/manager/META-INF/context.xml

    - name: start the tomcat
      shell: "nohup /opt/tomcat/bin/startup.sh &"
      async: 10
      poll: 0


