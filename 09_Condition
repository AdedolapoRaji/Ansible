WHEN CONDITION

TO INSTALL GIT ONLY IF THE SERVER IS REDHAT

---
- hosts: all
  become: yes
  tasks:
    - name: To install git on RedHat
      yum:
        name: git        # Just the package name here
        state: present
      when: ansible_os_family == "RedHat"

    - name: To install git on Ubuntu
      apt:               # IMPORTANT: Ubuntu uses 'apt', not 'yum'
        name: git
        state: present
      when: ansible_os_family == "Debian"


